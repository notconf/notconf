<netconf-server xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-server">
  <listen>
    <endpoints>
      <endpoint>
        <name>default-ssh</name>
        <ssh>
          <!-- Replace merge_config.sh's default local-bind (0.0.0.0); "::" is a
               single dual-stack listener. -->
          <tcp-server-parameters xmlns:nc="urn:ietf:params:xml:ns:netconf:base:1.0" nc:operation="replace">
            <local-bind>
              <local-address>::</local-address>
            </local-bind>
          </tcp-server-parameters>
          <ssh-server-parameters>
            <client-authentication>
              <users>
                <user>
                  <name>admin</name>
                  <password>
                    <hashed-password>$0$admin</hashed-password>
                  </password>
                </user>
              </users>
            </client-authentication>
          </ssh-server-parameters>
        </ssh>
      </endpoint>
    </endpoints>
  </listen>
</netconf-server>
